+def compute_refund_cents(order_total_cents: int, refund_fraction: float) -> int:
+    """Return the refund amount in whole cents for a partial refund.
+
+    refund_fraction is a value in [0, 1] (e.g. 0.5 for a 50% refund).
+    """
+    if not 0 <= refund_fraction <= 1:
+        raise ValueError(f"refund_fraction out of range: {refund_fraction}")
+    # Compute in Decimal and round half-up to whole cents so partial refunds
+    # match the payment gateway's penny totals instead of silently truncating.
+    raw = Decimal(order_total_cents) * Decimal(str(refund_fraction))
+    return int(raw.quantize(Decimal("1"), rounding=ROUND_HALF_UP))


