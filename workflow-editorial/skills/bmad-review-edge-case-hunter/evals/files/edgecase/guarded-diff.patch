+def safe_average(values):
+    if values is None or len(values) == 0:
+        return None
+    cleaned = []
+    for v in values:
+        if v is None:
+            continue
+        cleaned.append(v)
+    if len(cleaned) == 0:
+        return None
+    return sum(cleaned) / len(cleaned)
